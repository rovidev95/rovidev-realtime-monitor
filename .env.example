# HTTP + WebSocket port
PORT=8080

# How often a full snapshot is broadcast to dashboards (ms)
SNAPSHOT_INTERVAL_MS=5000

# Optional: JSON array of targets to monitor. Falls back to built-in defaults.
# MONITOR_TARGETS=[{"id":"api","name":"My API","url":"https://api.example.com/health","intervalMs":5000,"timeoutMs":4000}]
